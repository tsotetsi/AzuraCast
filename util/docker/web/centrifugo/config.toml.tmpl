# --- API / Admin ---
api_insecure = true

[admin]
enabled = true
insecure = true

# --- Client settings ---
allowed_origins = ["*"]
allow_anonymous_connect_without_token = true
connect_include_server_time = true

# --- Transport (v5 unified) ---
[sse]
enabled = true

[http_stream]
enabled = true

# --- Engine ---
[engine]
type = "redis"
redis_address = "keydb:6379"
redis_db = 0
redis_prefix = "centrifugo:c"

# --- Namespaces ---
[[namespaces]]
name = "station"
history_size = 1
history_ttl = "30s"
allow_subscribe_for_client = true
allow_subscribe_for_anonymous = true
allow_history_for_client = true
allow_history_for_anonymous = true
force_recovery = true
force_recovery_mode = "cache"